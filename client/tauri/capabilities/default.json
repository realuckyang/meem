{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for Meem main window",
  "windows": ["main"],
  "remote": {
    "urls": ["https://meem.chatnext.ai"]
  },
  "permissions": [
    "core:default",
    "allow-local-bridge-get",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/meem-bridge",
          "sidecar": true,
          "args": false
        }
      ]
    }
  ]
}
