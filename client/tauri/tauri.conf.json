{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meem",
  "version": "0.1.0",
  "identifier": "ai.meem.client",
  "build": {
    "beforeDevCommand": "npm run build:bridge",
    "beforeBuildCommand": "npm run build:bridge",
    "devUrl": "https://meem.chatnext.ai/",
    "frontendDist": "https://meem.chatnext.ai/"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Meem",
        "url": "https://meem.chatnext.ai/",
        "width": 420,
        "height": 720,
        "minWidth": 380,
        "minHeight": 660,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/meem-bridge"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Vidline Inc. (DY69LKWHQV)",
      "minimumSystemVersion": "10.15"
    }
  }
}
