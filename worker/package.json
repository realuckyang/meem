{
  "name": "meem-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm --prefix gui run build && wrangler deploy",
    "db:create": "wrangler d1 create meem",
    "db:migrate": "wrangler d1 execute meem --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute meem --local --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
